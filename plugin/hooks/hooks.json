{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "if": "Write(*.md)",
            "type": "command",
            "command": "bun run ${CLAUDE_PLUGIN_ROOT}/scripts/pre-edit.ts",
            "timeout": 30
          },
          {
            "if": "Edit(*.md)",
            "type": "command",
            "command": "bun run ${CLAUDE_PLUGIN_ROOT}/scripts/pre-edit.ts",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run ${CLAUDE_PLUGIN_ROOT}/scripts/on-stop.ts",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
