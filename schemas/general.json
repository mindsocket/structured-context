{
  "$schema": "https://raw.githubusercontent.com/mindsocket/ost-tools/main/schemas/generated/_ost_tools_schema_meta.json",
  "$id": "ost-tools://general",
  "title": "Strategy and opportunity ladder",
  "description": "Validates frontmatter for space node files",
  "$metadata": {
    "hierarchy": {
      "levels": [
        "vision",
        "mission",
        { "type": "goal", "selfRef": true },
        { "type": "opportunity", "selfRef": true },
        { "type": "solution", "selfRef": true },
        "experiment"
      ]
    },
    "aliases": {
      "outcome": "goal",
      "assumption_test": "experiment",
      "test": "experiment"
    },
    "relationships": [
      {
        "parent": "opportunity",
        "type": "problem_statement",
        "format": "heading",
        "matchers": ["Problem statement", "What problem are we solving?"],
        "multi": false
      },
      {
        "parent": "opportunity",
        "type": "assumption",
        "format": "table",
        "matchers": ["Assumptions", "^Assumptions?$"],
        "embeddedTemplateFields": ["assumption", "status", "confidence"],
        "multi": true
      }
    ]
  },
  "oneOf": [
    {
      "type": "object",
      "allOf": [{ "$ref": "ost-tools://_ost_tools_base#/$defs/baseNodeProps" }],
      "properties": {
        "type": { "const": "dashboard" }
      },
      "required": ["type"],
      "additionalProperties": true
    },
    {
      "type": "object",
      "allOf": [{ "$ref": "ost-tools://_ost_tools_base#/$defs/baseNodeProps" }],
      "properties": {
        "type": { "enum": ["ost_on_a_page", "space_on_a_page"] }
      },
      "required": ["type"],
      "additionalProperties": true
    },
    {
      "type": "object",
      "allOf": [
        { "$ref": "ost-tools://_ost_tools_base#/$defs/baseNodeProps" },
        { "$ref": "ost-tools://_ost_tools_base#/$defs/ostEntityProps" }
      ],
      "properties": {
        "type": { "const": "vision" }
      },
      "required": ["type"],
      "not": { "required": ["parent"] },
      "additionalProperties": true,
      "examples": [
        {
          "type": "vision",
          "status": "active"
        }
      ]
    },
    {
      "type": "object",
      "allOf": [
        { "$ref": "ost-tools://_ost_tools_base#/$defs/baseNodeProps" },
        { "$ref": "ost-tools://_ost_tools_base#/$defs/parentNodeProps" },
        { "$ref": "ost-tools://_ost_tools_base#/$defs/ostEntityProps" }
      ],
      "properties": {
        "type": { "const": "mission" }
      },
      "required": ["type"],
      "additionalProperties": true,
      "examples": [
        {
          "type": "mission",
          "status": "active",
          "parent": "[[Personal Vision]]"
        }
      ]
    },
    {
      "type": "object",
      "allOf": [
        { "$ref": "ost-tools://_ost_tools_base#/$defs/baseNodeProps" },
        { "$ref": "ost-tools://_ost_tools_base#/$defs/parentNodeProps" },
        { "$ref": "ost-tools://_ost_tools_base#/$defs/ostEntityProps" }
      ],
      "properties": {
        "type": { "enum": ["goal", "outcome"] },
        "priority": { "$ref": "ost-tools://_ost_tools_base#/$defs/priority" }
      },
      "required": ["type"],
      "additionalProperties": true,
      "examples": [
        {
          "type": "goal",
          "status": "active",
          "parent": "[[My Mission (2026)]]",
          "priority": "p2"
        }
      ]
    },
    {
      "type": "object",
      "allOf": [
        { "$ref": "ost-tools://_ost_tools_base#/$defs/baseNodeProps" },
        { "$ref": "ost-tools://_ost_tools_base#/$defs/parentNodeProps" },
        { "$ref": "ost-tools://_ost_tools_base#/$defs/ostEntityProps" }
      ],
      "properties": {
        "type": { "const": "opportunity" },
        "priority": { "$ref": "ost-tools://_ost_tools_base#/$defs/priority" },
        "impact": { "$ref": "ost-tools://_ost_tools_base#/$defs/assessment" },
        "feasibility": { "$ref": "ost-tools://_ost_tools_base#/$defs/assessment" },
        "resources": { "$ref": "ost-tools://_ost_tools_base#/$defs/assessment" },
        "timeline": {
          "type": "string",
          "description": "Timeline estimate (e.g., S-M, M-L)"
        },
        "next_steps": {
          "type": "string",
          "description": "Next steps for this opportunity"
        }
      },
      "required": ["type"],
      "additionalProperties": true,
      "examples": [
        {
          "type": "opportunity",
          "status": "identified",
          "parent": "[[Career Growth]]",
          "priority": "p2"
        }
      ]
    },
    {
      "type": "object",
      "allOf": [
        { "$ref": "ost-tools://_ost_tools_base#/$defs/baseNodeProps" },
        { "$ref": "ost-tools://_ost_tools_base#/$defs/parentNodeProps" },
        { "$ref": "ost-tools://_ost_tools_base#/$defs/ostEntityProps" }
      ],
      "properties": {
        "type": { "const": "solution" },
        "priority": { "$ref": "ost-tools://_ost_tools_base#/$defs/priority" },
        "impact": { "$ref": "ost-tools://_ost_tools_base#/$defs/assessment" },
        "feasibility": { "$ref": "ost-tools://_ost_tools_base#/$defs/assessment" },
        "resources": { "$ref": "ost-tools://_ost_tools_base#/$defs/assessment" },
        "timeline": {
          "type": "string",
          "description": "Timeline estimate (e.g., S-M, M-L)"
        },
        "next_steps": {
          "type": "string",
          "description": "Next steps for this solution"
        }
      },
      "required": ["type"],
      "additionalProperties": true,
      "examples": [
        {
          "type": "solution",
          "status": "identified",
          "parent": "[[Some Opportunity]]",
          "priority": "p3"
        }
      ]
    },
    {
      "type": "object",
      "allOf": [
        { "$ref": "ost-tools://_ost_tools_base#/$defs/baseNodeProps" },
        { "$ref": "ost-tools://_ost_tools_base#/$defs/parentNodeProps" },
        { "$ref": "ost-tools://_ost_tools_base#/$defs/ostEntityProps" }
      ],
      "properties": {
        "type": { "enum": ["experiment", "assumption_test", "test"] }
      },
      "required": ["type"],
      "additionalProperties": true,
      "examples": [
        {
          "type": "experiment",
          "status": "exploring",
          "parent": "[[Build a Side Project]]"
        },
        {
          "type": "test",
          "status": "active",
          "parent": "[[Mobile App Solution]]"
        }
      ]
    },
    {
      "type": "object",
      "allOf": [
        { "$ref": "ost-tools://_ost_tools_base#/$defs/baseNodeProps" },
        { "$ref": "ost-tools://_ost_tools_base#/$defs/parentNodeProps" },
        { "$ref": "ost-tools://_ost_tools_base#/$defs/ostEntityProps" }
      ],
      "properties": {
        "type": { "const": "assumption" },
        "confidence": {
          "type": "string",
          "enum": ["low", "medium", "high"],
          "description": "Confidence level in this assumption"
        }
      },
      "required": ["type"],
      "additionalProperties": true,
      "examples": [
        {
          "type": "assumption",
          "status": "identified",
          "parent": "[[Some Opportunity]]",
          "confidence": "medium"
        }
      ]
    },
    {
      "type": "object",
      "allOf": [
        { "$ref": "ost-tools://_ost_tools_base#/$defs/baseNodeProps" },
        { "$ref": "ost-tools://_ost_tools_base#/$defs/parentNodeProps" },
        { "$ref": "ost-tools://_ost_tools_base#/$defs/ostEntityProps" }
      ],
      "properties": {
        "type": { "const": "problem_statement" }
      },
      "required": ["type"],
      "additionalProperties": true,
      "examples": [
        {
          "type": "problem_statement",
          "status": "identified"
        }
      ]
    }
  ]
}
