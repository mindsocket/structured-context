{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Opportunity Solution Tree Node",
  "description": "Validates frontmatter for OST node files",
  "oneOf": [
    {
      "type": "object",
      "allOf": [{ "$ref": "#/$defs/baseNodeProps" }],
      "properties": {
        "type": { "const": "dashboard" }
      },
      "required": ["type"],
      "additionalProperties": true
    },
    {
      "type": "object",
      "allOf": [{ "$ref": "#/$defs/baseNodeProps" }],
      "properties": {
        "type": { "const": "ost_on_a_page" }
      },
      "required": ["type"],
      "additionalProperties": true
    },
    {
      "type": "object",
      "allOf": [
        { "$ref": "#/$defs/baseNodeProps" },
        { "$ref": "#/$defs/ostEntityProps" }
      ],
      "properties": {
        "type": { "const": "vision" }
      },
      "required": ["type"],
      "not": { "required": ["parent"] },
      "additionalProperties": true,
      "examples": [
        {
          "type": "vision",
          "status": "active"
        }
      ]
    },
    {
      "type": "object",
      "allOf": [
        { "$ref": "#/$defs/baseNodeProps" },
        { "$ref": "#/$defs/ostEntityProps" }
      ],
      "properties": {
        "type": { "const": "mission" },
        "parent": { "$ref": "#/$defs/wikilink" }
      },
      "required": ["type"],
      "additionalProperties": true,
      "examples": [
        {
          "type": "mission",
          "status": "active",
          "parent": "[[Personal Vision]]"
        }
      ]
    },
    {
      "type": "object",
      "allOf": [
        { "$ref": "#/$defs/baseNodeProps" },
        { "$ref": "#/$defs/ostEntityProps" }
      ],
      "properties": {
        "type": { "const": "goal" },
        "parent": { "$ref": "#/$defs/wikilink" },
        "priority": { "$ref": "#/$defs/priority" }
      },
      "required": ["type"],
      "additionalProperties": true,
      "examples": [
        {
          "type": "goal",
          "status": "active",
          "parent": "[[My Mission (2026)]]",
          "priority": "p2"
        }
      ]
    },
    {
      "type": "object",
      "allOf": [
        { "$ref": "#/$defs/baseNodeProps" },
        { "$ref": "#/$defs/ostEntityProps" }
      ],
      "properties": {
        "type": { "const": "opportunity" },
        "parent": { "$ref": "#/$defs/wikilink" },
        "priority": { "$ref": "#/$defs/priority" },
        "impact": { "$ref": "#/$defs/assessment" },
        "feasibility": { "$ref": "#/$defs/assessment" },
        "resources": { "$ref": "#/$defs/assessment" },
        "timeline": {
          "type": "string",
          "description": "Timeline estimate (e.g., S-M, M-L)"
        },
        "next_steps": {
          "type": "string",
          "description": "Next steps for this opportunity"
        }
      },
      "required": ["type"],
      "additionalProperties": true,
      "examples": [
        {
          "type": "opportunity",
          "status": "identified",
          "parent": "[[Career Growth]]",
          "priority": "p2"
        }
      ]
    },
    {
      "type": "object",
      "allOf": [
        { "$ref": "#/$defs/baseNodeProps" },
        { "$ref": "#/$defs/ostEntityProps" }
      ],
      "properties": {
        "type": { "const": "solution" },
        "parent": {
          "$ref": "#/$defs/wikilink",
          "description": "Parent opportunity or solution (wikilink)"
        },
        "priority": { "$ref": "#/$defs/priority" },
        "impact": { "$ref": "#/$defs/assessment" },
        "feasibility": { "$ref": "#/$defs/assessment" },
        "resources": { "$ref": "#/$defs/assessment" },
        "timeline": {
          "type": "string",
          "description": "Timeline estimate (e.g., S-M, M-L)"
        },
        "next_steps": {
          "type": "string",
          "description": "Next steps for this solution"
        }
      },
      "required": ["type"],
      "additionalProperties": true,
      "examples": [
        {
          "type": "solution",
          "status": "identified",
          "parent": "[[Some Opportunity]]",
          "priority": "p3"
        }
      ]
    }
  ],
  "$defs": {
    "baseNodeProps": {
      "type": "object",
      "properties": {
        "title": { "$ref": "#/$defs/title" },
        "content": { "$ref": "#/$defs/content" },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Categorization tags"
        }
      },
      "required": ["title"]
    },
    "ostEntityProps": {
      "type": "object",
      "properties": {
        "status": { "$ref": "#/$defs/status" },
        "summary": { "$ref": "#/$defs/summary" },
        "status_tweet": {
          "type": "string",
          "description": "Succinct free-text status summary"
        }
      },
      "required": ["status"]
    },
    "title": {
      "type": "string",
      "description": "Title of the node (derived from filename at validation time)"
    },
    "content": {
      "type": "string",
      "description": "Body content of the document (excluding frontmatter)"
    },
    "summary": {
      "type": "string",
      "description": "Short summary of the node"
    },
    "status": {
      "type": "string",
      "enum": [
        "identified",
        "wondering",
        "exploring",
        "active",
        "paused",
        "completed",
        "archived"
      ]
    },
    "priority": {
      "type": "string",
      "enum": ["p1", "p2", "p3", "p4"]
    },
    "assessment": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5,
      "description": "Assessment score from 1-5"
    },
    "wikilink": {
      "type": "string",
      "pattern": "^\\[\\[.+\\]\\]$",
      "description": "An Obsidian wikilink, e.g. [[Parent Node]]"
    }
  }
}
